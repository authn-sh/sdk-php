{
    "name": "authn-sh/sdk-php",
    "description": "PHP backend SDK for authn.sh — BAPI client, JWT verification, webhook signature verification, Laravel package.",
    "keywords": [
        "authn",
        "authentication",
        "identity",
        "sdk"
    ],
    "license": "AGPL-3.0-only",
    "type": "library",
    "homepage": "https://authn.sh",
    "support": {
        "issues": "https://github.com/authn-sh/sdk-php/issues",
        "source": "https://github.com/authn-sh/sdk-php"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/log": "^3.0",
        "web-token/jwt-library": "^4.0",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.1",
        "laravel/pint": "^1.10",
        "nyholm/psr7": "^1.8",
        "guzzlehttp/guzzle": "^7.8",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Authn\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Authn\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "pint": "vendor/bin/pint --test",
        "pint:fix": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Authn\\Sdk\\Laravel\\AuthnServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
